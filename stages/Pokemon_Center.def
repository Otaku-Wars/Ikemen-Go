;--------------------------------------------------------
[Info]
name = "Jhoto - Pokemon Center"

;--------------------------------------------------------
[Camera]
startx = 0
starty = 0

boundleft = -65
boundright = 100

boundhigh = 20
boundlow = 0

verticalfollow = 0.6
tension = 100

;--------------------------------------------------------
[PlayerInfo]
;--- Player 1 ---
 ;Player 1 starting coordinates.
 ;p1startx is typically -70 and p2startx is 70.
 ;p1starty and p1startz should be 0.
p1startx = -70          ;Starting x coordinates
p1starty = 0            ;Starting y coordinates
p1startz = 0            ;Starting z coordinates
p1facing = 1            ;Direction player faces: 1=right, -1=left

;--- Player 2 ---
p2startx = 70
p2starty = 0
p2startz = 0
p2facing = -1

;--- Common ---
 ;Don't change these values.
leftbound  = -1000 ;Left bound (x-movement)
rightbound =  1000 ;Right bound
topbound  =  0     ;Top bound (z-movement)
botbound  =  0     ;Bottom bound

;--------------------------------------------------------
[Scaling]
 ;No need to change these values
topz     = 0       ;Top z-coordinate for scaling
botz     = 50      ;Bottom z-coordinate for scaling
topscale = 1       ;Scale to use at top
botscale = 1     ;Scale to use at bottom

;--------------------------------------------------------
[Bound]
 ;Distance from left/right edge of screen that player can move to
 ;Typically 15
screenleft = 15    ;Dist from left of screen that player can move to
screenright = 15   ;Right edge

;--------------------------------------------------------
[StageInfo]
zoffset = 210
autoturn = 1
resetBG = 1

[Shadow]
color = 0,0,0
yscale = .2

;--------------------------------------------------------
[Music]
bgmusic = sound/87 - Pok_mon Center Theme - Pok_mon Red - Blue - Green.mp3
bgmusic = sound/Pokemon - Diamond & Pearl - Pokemon Center 1.mid
bgvolume = 255
bgm.loop = 1


;-------------------------------------
; Main background definition
[BGdef]
spr = Pokemon_Center.sff
debugbg = 1


;-------------
[bg PC Ground]
type  = parallax
spriteno = 0, 0
delta = 1, 1
xscale = .6, 1.1
yscaledelta = 0
mask  = 1

[BG Wall]
type = normal
spriteno = 6,0
delta = 1,1
tile = 0, 0
layerno = 0
mask  = 1

[BG Monitor]
type = anim
actionno = 1
start = 0,0
delta = 1,1
mask = 1

[BG Joy]
type = normal
spriteno = 1,0
delta = 1,1
tile = 0, 0
layerno = 0
mask  = 1

[BG Shelf]
type = normal
spriteno = 2,0
delta = 1,1
mask = 1

[BG Red Chair]
type = normal
spriteno = 3,0
delta = 1.2,1.2
mask = 1

[BG Yellow Chair]
type = normal
spriteno = 3,2
delta = 1.2,1.2
mask = 1

[BG Computer]
type = normal
spriteno = 8,0
delta = 1,1
mask = 1

[BG Map]
type = normal
spriteno = 9,0
delta = 1,1
mask = 1

[BG Joy's Eyes]
type = anim
actionno = 0
start = 0,0
delta = 1,1
mask = 1



