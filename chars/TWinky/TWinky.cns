
; Constants and state file.
; There are comments scattered through this file, so you may like to
; take a look if would like to learn more about the cns.

[Data]
life = 1000			;Amount of life to start with
power = 3000		;Amount of maximum power
attack = 350		;attack power (more is stronger)
defence = 300		;defensive power (more is stronger)
fall.defence_up = 50	;Percentage to increase defense everytime player is knocked down
liedown.time = 30		;Time which player lies down for, before getting up
airjuggle = 30		;Number of points for juggling
sparkno = 30			;Default hit spark number for HitDefs
guard.sparkno = 40	;Default guard spark number
KO.echo = 1			;1 to enable echo on KO
volume = 0			;Volume offset (negative for softer)
IntPersistIndex = 50	;Variables with this index and above will not have their values
FloatPersistIndex = 50  ;reset to 0 between rounds or matches. There are 60 int variables,
  				;indexed from 0 to 59, and 40 float variables, indexed from 0 to 39.
  				;If omitted, then it defaults to 60 and 40 for integer and float
  				;variables repectively, meaning that none are persistent, i.e. all
  				;are reset. If you want your variables to persist between matches,
  				;you need to override state 5900 from common1.cns.


[Size]
xscale = 1			;Horizontal scaling factor.
yscale = 1			;Vertical scaling factor.
ground.back = 15		;Player width (back, ground)
ground.front = 16		;Player width (front, ground)
air.back = 12		;Player width (back, air)
air.front = 12		;Player width (front, air)
height = 60			;Height of player (for opponent to jump over)
attack.dist = 160		;Default attack distance
proj.attack.dist = 90	;Default attack distance for projectiles
proj.doscale = 0		;Set to 1 to scale projectiles too   
head.pos = -5, -90	;Approximate position of head
mid.pos = -5, -60		;Approximate position of midsection
shadowoffset = 0		;Number of pixels to vertically offset the shadow
draw.offset = 0,0		;Player drawing offset in pixels (x, y)

[Velocity]
walk.fwd  = 2.4		;Walk forward
walk.back = -2.2		;Walk backward
run.fwd  = 4.6, 0		;Run forward (x, y)
run.back = -4.5,-3.8	;Hop backward (x, y)
jump.neu = 0,-8.4		;Neutral jumping velocity (x, y)
jump.back = -2.55		;Jump back Speed (x, y)
jump.fwd = 2.5		;Jump forward Speed (x, y)
runjump.back = -2.55,-8.1;Running jump speeds (opt)
runjump.fwd = 4,-8.1	;.
airjump.neu = 0,-8.1	;.
airjump.back = -2.55	;Air jump speeds (opt)
airjump.fwd = 2.5		;.

[Movement]
airjump.num = 1		;Number of air jumps allowed (opt)
airjump.height = 35	;Minimum distance from ground before you can air jump (opt)
yaccel = .44		;Vertical acceleration
stand.friction = .85	;Friction coefficient when standing
crouch.friction = .82	;Friction coefficient when crouching

;---------------------------------------------------------------------------
; Format:
; [Statedef STATENO]
; type = ?      S/C/A/L  stand/crouch/air/liedown
; movetype = ?  I/A/H    idle/attack/gethit
; physics = ?   S/C/A/N  stand/crouch/air/none
; juggle = ?             air juggle points move requires
;
; [State STATENO, ?]     ? - any number you choose
; type = ?
; ...

;---------------------------------------------------------------------------
; Lose by Time Over
; CNS difficulty: basic
[Statedef 170]
type = S
ctrl = 0
anim = 170
velset = 0,0

[State 1000, Snd]
type = PlaySnd
trigger1 = AnimElem = 1
value = 1000,3

[State 170, 1]
type = NotHitBy
trigger1 = 1
value = SCA
time = 1

;---------------------------------------------------------------------------
; Win state decider
; CNS difficulty: basic
[Statedef 180]
type = S

[State 180, 0]
type = varrandom
trigger1 = 1
v = 13
range = 1,3; depends on how many intros u have, you can put 1,3 so you can have three intros

[State 180, 0]
type = changestate
trigger1 = var(13) = 1
trigger1 = time = 0
value = 181

[State 180, 0]
type = changestate
trigger1 = var(13) = 2
trigger1 = time = 0
value = 182

[State 180, 0]
type = changestate
trigger1 = var(13) = 3
trigger1 = time = 0
value = 183



;---------------------------------------------------------------------------
; Win pose 1
; CNS difficulty: basic
[Statedef 181]
type = S
ctrl = 0
anim = 180
velset = 0,0

[State 181, 1]
type = NotHitBy
trigger1 = 1
value = SCA
time = 1

[State 1000, Snd]
type = PlaySnd
trigger1 = AnimElem = 3
value = 5000,1

;---------------------------------------------------------------------------
;Win pose 2
 [Statedef 182]
type = S
ctrl = 0
anim = 181
velset = 0,0

[State 3000, EnvShake]
type = EnvShake ;
trigger1 = AnimElem = 2
time = 13
freq = 60 ;
ampl = -4 ;
phase = 90 ;

[State 182, Snd]
type = PlaySnd
trigger1 = AnimElem = 3
value = 1000,1
volume = 200

[State 182, Snd]
type = PlaySnd
trigger1 = AnimElem = 2
value = 200,8

[State 182, 1]
type = NotHitBy
trigger1 = 1
value = SCA
time = 1
;---------------------------------------------------------------------------
;Win 3
[Statedef 183]
type = S
ctrl = 0
anim = 182
velset = 0,0

[State 182, Snd]
type = PlaySnd
trigger1 = AnimElem = 1
value = 200,14
volume = 200

[State 182, Snd]
type = PlaySnd
trigger1 = AnimElem = 2
value = 200,9
volume = 200

[State 0, VelAdd]
type = VelAdd
trigger1 = AnimElem = 11
trigger2 = AnimElem = 12
trigger3 = AnimElem = 13
trigger4 = AnimElem = 14
trigger5 = AnimElem = 15
trigger6 = AnimElem = 16
trigger7 = AnimElem = 17
trigger8 = AnimElem = 18
x = -1.6
y = 0

[State 180, 1]
type = AssertSpecial
trigger1 = time = [0,500]
flag = RoundNotOver


;---------------------------------------------------------------------------
; Introduction
; CNS difficulty: basic
[Statedef 190]
type = S
ctrl = 0
anim = 0
velset = 0,0

[State 190, 0]
type = varrandom
trigger1 = 1
v = 13
range = 1,4; depends on how many intros u have, you can put 1,3 so you can have three intros

[State 190, 0]
type = changestate
trigger1 = var(13) = 1
trigger1 = time = 0
value = 191

[State 190, 0]
type = changestate
trigger1 = var(13) = 2
trigger1 = time = 0
value = 192

[State 190, 0]
type = changestate
trigger1 = var(13) = 3
trigger1 = time = 0
value = 193

[State 190, 0]
type = changestate
trigger1 = var(13) = 4
trigger1 = time = 0
value = 194

;---------------------------------------------------------------------------
;Intro 1

[Statedef 191]
type = S
ctrl = 0
anim = 190
velset = 0,0
poweradd = 1000

[State 190, 1] ;Freeze animation until PreIntro is over
type = ChangeAnim
trigger1 = RoundState = 0
value = 190

[State 190, 2] ;Assert this until you want "round 1, fight" to begin
type = AssertSpecial
trigger1 = 1
flag = Intro

[State 190, Snd]
type = PlaySnd
trigger1 = AnimElem = 23
value = 1000,1

[State 190, End]
type = ChangeState
trigger1 = animtime = 0
value = 0

;--------------------------------------------------------------------------
;Intro 2

