;----------------------------------------------------------------------
;Magic Scroll
[StateDef 1000]
type = S
physics = S
moveType = A
anim = 1000
ctrl = 0
velSet = 0,0
sprPriority = 1
powerAdd = 72 * (!var(20)&&!var(53))
faceP2 = 1

[State 1000, Button Detect]
type = VarSet
trigger1 = !Time && !AILevel
var(10) = ifElse((command = "x" || command = "rlsx"), 0, ifElse((command = "z" || command = "rlsz"), 2, 1))

[State 1000, Button Detect (AI)]
type = VarSet
trigger1 = !Time && AILevel
var(10) = ifElse((P2MoveType = H || Random < 500), 2, ifElse(Random < 500, 1, 0))

[State 1000, Button Detect (Add004)]
type = VarSet
trigger1 = (var(58)&&sysfvar(4)=1) && !time
var(10) = 1
ignorehitpause = 1

[State 1000, ChangeAnim]
type = ChangeAnim
trigger1 = !Time
value = ifElse(var(10) = 0, 1000, ifElse(var(10) = 1, 1000, 1000))

[State 1000, Voice]
type = PlaySnd
trigger1 = AnimElem = 5
value = 1000,var(10)
channel = 0

[State 1000, Thunder Spear Startup Sound]
type = PlaySnd
trigger1 = AnimElem = 5 && var(10) = 0
value = 1005, 0
channel = 6

[State 1000, Ice Bolt Startup Sound]
type = PlaySnd
trigger1 = AnimElem = 5 && var(10) = 1
value = 1090, 0
channel = 6

[State 1000, Magic Item]
type = Helper
trigger1 = AnimElem = 5
helperType = Normal
stateNo = 1090
ID = 1090
name = "Magic Item"
posType = P1
pos = ceil(76*const(size.xscale)),ceil(-397*const(size.yscale))
size.xScale = const(size.xscale)
size.yScale = const(size.yscale)
ownPal = 1

[State 1000, Projectile - Thunder Spear]
type = Helper
trigger1 = AnimElem = 5 && var(10) = 0
helperType = Normal
stateNo = 1005
ID = 1005
name = "Thunder Spear Projectile"
posType = P1
pos = ceil(90*const(size.xscale)),ceil(-214*const(size.yscale))
size.xScale = const(size.xscale)
size.yScale = const(size.yscale)
ownPal = 1

[State 1000, Projectile - Ice Bolt]
type = Helper
trigger1 = AnimElem = 5 && var(10) = 1
helperType = Normal
stateNo = 1010
ID = 1010
name = "Ice Bolt Projectile"
posType = P1
pos = ceil(105*const(size.xscale)),ceil(-500*const(size.yscale))
size.xScale = const(size.xscale)
size.yScale = const(size.yscale)
ownPal = 1

[State 1000, Projectile - Flame Charge]
type = Helper
trigger1 = AnimElem = 5 && var(10) = 2
helperType = Normal
stateNo = 1015
ID = 1015
name = "Flame Charge Projectile"
posType = P1
pos = 140,0
size.xScale = const(size.xscale)
size.yScale = 0.8 * const(size.yscale)
ownPal = 1

[State 1000, Dust]
type = explod
trigger1 = animelem = 5, >= 0 && animelem = 17, <0
anim = 8105
sprpriority = -3
postype = p1
pos = 0, 0
scale = 0.5, 0.5
pausemovetime = -1
supermovetime = -1
ownpal = 1
persistent = 6
remappal = 8001,0

[State 1000, AttackDist]
Type = AttackDist
Trigger1 = AnimElemTime(5)>0 && !var(39)
Trigger2 = var(10) > 1
Value = 0
Persistent = 1

[State 1000, Type]
type=statetypeset
trigger1= animelemtime(17)>=0
movetype=I

[State 1000, End]
type = ChangeState
trigger1 = !AnimTime
value = 0
ctrl = 1
