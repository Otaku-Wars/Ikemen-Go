moveType = A
anim = 1100
ctrl = 0
velSet = 0,0
sprPriority = 1
powerAdd = 72 * (!var(20)&&!var(53))
faceP2 = 1

[State 1100, Button Detect]
type = VarSet
trigger1 = !Time && !AILevel
var(10) = ifElse((command = "x" || command = "rlsx"), 0, ifElse((command = "y" || command = "rlsy"), 1, 2))

[State 1100, Button Detect (AI)]
type = VarSet
trigger1 = !Time && AILevel
var(10) = ifElse((P2MoveType = H || Random < 500), 2, ifElse(Random < 500, 1, 0))

[State 1100, ChangeAnim]
type = ChangeAnim
trigger1 = !Time
value = ifElse(var(10) = 0, 1100, ifElse(var(10) = 1, 1100, 1100))

[State 1100, Snd]
type = playsnd
trigger1 = animelem = 4|animelem = 12
value = 1, 5
channel = 1
[State 1100, Snd]
type = playsnd
trigger1 = animelem = 4
value = 1100, random%3
channel = 0

[State 1100, Vel]
type = velset
trigger1 = !Time
x = 3 + (0.75*var(10))
y = -5 + 1.5*(PrevStateNo = 1100)

[State 1100, Vel]
type = veladd
trigger1 = Time > 0
y = .45

[State 1100, Remove Explod]
type=removeexplod
trigger1= !Time && NumExplod(1105)
id = 1105
ignorehitpause = 1

[State 1100, FX]
type = Explod
trigger1 = AnimElem = 4
anim = 1105
id = 1105
pos = ceil(-18*const(size.yScale)),ceil(-242*const(size.yScale))
postype = p1
bindtime = -1
scale = 0.55*const(size.xScale),0.15*const(size.yScale)
sprpriority = 5
ontop = 0
ownpal = 1
removetime = -1
removeongethit = 1
ignorehitpause = 0

[State 1100, Hit]
type = hitdef
trigger1 = AnimElem = 4, >= 0 && !MoveContact && !MoveReversed
attr = A, SA
damage = ceil(ifelse(fvar(11) * 80 < 12 - 5*(var(20)>0), 12 - 5*(var(20)>0), fvar(11) * 80)), 12 - 5*(var(20)>0)
animtype = Hard
guardflag = HA
hitflag = MAF
priority = 4, Hit
pausetime = ifelse(var(20), 4, 8), ifelse(var(20), 4, 8)
guard.pausetime = ifelse(var(20), 4, 8), ifelse(var(20), 4, 8)
sparkNo = -1 + 0 * (var(33) := 8013)
guard.sparkNo = -1 + 0 * (var(34) := 8001)
sparkXY = 0,0;-10 + 0*(var(35):=36), var(36):=-15
hitSound = s-1, (var(31) := 2)
guardSound = s-1, (var(32) := 0)
ground.type = High
ground.slidetime = 10
ground.hittime = 10
ground.velocity = -5 * ifelse(p2dist x < 0, -1, 1), -4
ground.cornerPush.velOff = 0
guard.velocity = ifElse(var(20), -5, -10) * ifelse(p2dist x < 0, -1, 1)
guard.cornerPush.velOff = 0
air.type = Low
air.velocity =  -5 * ifelse(p2dist x < 0, -1, 1), -4
air.cornerPush.velOff = 0
airguard.velocity =  -4.5 * ifelse(p2dist x < 0, -1, 1), -1.5
airguard.cornerPush.velOff = 0
down.hittime = 30
down.velocity = 0, 0
getpower = ifElse(!var(13), 72, 36) * (!var(20)&&!var(53)), 12 * (!var(20)&&!var(53))
givepower = 36, 36
envshake.time = 12
envshake.freq = 120
envshake.ampl = 3
fall = 1
air.fall = 1
fall.recover = 1
fall.recovertime = 120
yaccel = 0.5
airguard.ctrltime = 16
airguard.velocity = ifelse(var(20), -4, -8), -1.5
airguard.cornerpush.veloff = 0
palFX.time = 12 * var(9)
palFX.add = 255, 255, 255
palFX.sinAdd= -255, -255, -255, 48
envShake.time = 14
envShake.ampl = 4
envShake.freq = 120

[State 1100, Hit Sparks Pos]
type = Null
trigger1 = 1||var(35):=ifElse(P2Dist x >= 0, 54, -66)
trigger1 = 1||var(36):=-73;ceil(P2Dist y + (EnemyNear, Const(size.mid.pos.y)))
ignoreHitPause = 1

[State 1100, End]
type = changestate
trigger1 = pos y > -vel y
value = 1104


