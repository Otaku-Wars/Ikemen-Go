[Quotes]
victory0 = "Mi nueva tecnica derriba incluso los muros mas gruesos!"
victory1 = "Nunca me retracto de lo que digo. Ese es mi camino ninja!!"
victory2 = "Soy el ninja que se convertira en Hokage! No perdere, sea quien sea mi contrincante!"
victory3 = "Nunca Falto a mi palabra! Ese es mi camino ninja!"
victory4 = "Algun dia obtendre el titulo de Hokage y sere el mejor que ha habido!"
victory5 = "Lo demostrare. Demostrare al mundo que tiene un heroe!"
