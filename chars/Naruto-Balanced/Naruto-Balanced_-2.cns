;=============================================================================
;============================= OPTIONS =========================================
;=============================================================================
;
; To set the Success Rate, go to this state and change the number on the
; line highlighted to what number you want.
;
;====================  Valid Values  =========================================
; 0 : Off - 100% success rate
; 1 : On - 30% success rate

[State Success Rate]
type = Varset
trigger1 = 1
v = 23
value = 0 ; <- Set to whatever value you want.

