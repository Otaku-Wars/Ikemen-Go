[State 0, DisplayToClipboard]
type = DisplaytoClipboard
trigger1 = 1
text = "%d = Explods"
params = numexplod

[State 0, DisplayToClipboard]
type = appendToClipboard
trigger1 = 1
text = "\n%d = roundstate"
params = roundstate

