triggerall = anim = 183
trigger1 = timemod = 4,0
anim = f120
pos = 5,-2
postype = p1
sprpriority = 4
ownpal = 1

[State 0, AssertSpecial]
type = AssertSpecial
triggerall = anim = 183
trigger1 = time <= 200
flag = roundnotover

[State 3080]
type = ScreenBound
trigger1 = 1
value = 0
;movecamera = 0,0


