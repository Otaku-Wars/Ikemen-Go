trigger1 = anim = 183
x = 7;const(velocity.run.fwd.x)

[State 100, 3] ;Prevent from turning
type = AssertSpecial
trigger1 = anim = 183
flag = NoAutoTurn
ignorehitpause = 1

[State 100, 4]
type = AfterImage
triggerall = anim = 183
trigger1 = timemod = 5,0
time = 5
trans = add1
timegap = 1
framegap = 2
length = 15
palbright = 12,12,12
palcontrast = 60,60,225
palpostbright = 0,0,0
paladd = 0,0,0
palmul = 1,1,1

[State running dust]
