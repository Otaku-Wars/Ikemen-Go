;Slash
[Statedef 300]
physics  = N
anim = 300
ctrl = 0
velset=0,0
sprpriority=4

[State 300, Trans]
type = Trans
trigger1 =time<4
trans = add
ignorehitpause =1

[State 300, Trans]
type = Trans
trigger1 =time>=4
trans = addalpha
alpha = 256-75*(time-4),256
ignorehitpause =1

[State 300, Scale]
type = AngleDraw
trigger1 = 1
scale = .5-.05*time,2.25

[State 300, Rotate]
type = AngleSet
trigger1 = !Time
value = 80

[State 300, BindToRoot]
type = BindToRoot
trigger1 =1
pos = ceil(125 * const(size.xScale)), ceil(-243 * const(size.yScale))
ignorehitpause =1
[State 300, Assert]
type = AssertSpecial
Trigger1 = 1
flag = noshadow
ignorehitpause =1
[State 300, Destroyself]
type = destroyself
trigger1 =root,stateno!=200&&root,stateno!=3410&&root,stateno!=3610&&root,stateno!=3660
trigger2 =root,Movetype=H
trigger3 =time>7
trigger4 =root,stateno=200&&root,animelem=2,<0
