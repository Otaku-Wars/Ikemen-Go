[Statedef 184]
type = S
physics = N
anim = 184
sprpriority = 2

[State 184, Vel]
type = velset
trigger1 = 1
x = 4

[State 184, End]
type = destroyself
trigger1 = root,anim=183
;========================<CAPE>=============================
[Statedef 194]
physics = N
anim = 194
sprpriority = 2
velset = 3, -3

[State 193, Acceleration]
type = VelAdd
trigger1 = 1
y = 0.1

[State 193, FadeOut]
type = Trans
trigger1 = 1
trans = AddAlpha
alpha = ceil(256 - 13 * Time), 13 * Time

[State 193, End]
type = DestroySelf
trigger1 = Time >= 20
