helpertype = normal ;player
name ="slash"
ID =1405
stateno =1405
pos = 0,0
postype = p1
ownpal = 1
persistent=0

[State 1400, Hit]
type=hitdef
trigger1= AnimElem = 5
forcenofall = !var(20)
attr = A,SA
hitflag = MAFD
guardflag = HA
damage = ceil(ifElse(fvar(11) * 100 < 14, 14, fvar(11) * 100)), 14
getPower = 0, 0
givePower = 18, 18
pauseTime = ifElse(var(20), 6, 12), ifElse(var(20), 6, 12)
guard.pauseTime = ifElse(var(20), 6, 12), ifElse(var(20), 6, 12)
animtype = Hard
air.animtype = Back
fall.animtype = Back
ground.type = High
air.type = Low
ground.hittime = 18
ground.slidetime = 18
guard.hittime = 18
air.hittime = 120
airguard.ctrltime = 16
