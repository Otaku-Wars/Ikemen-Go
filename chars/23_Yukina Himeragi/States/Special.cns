ground.cornerPush.velOff = 0
guard.velocity = ifElse(var(20), -1, -1)
guard.cornerPush.velOff = 0
air.velocity = -1, 15
air.cornerPush.velOff = 0
airguard.velocity = -5, 5
airguard.cornerPush.velOff = 0
yAccel = 0.58
fall = 1
fall.recover = 0
fall.recoverTime = 120
hitsound = s-1 + 0, (var(31):=9)
guardsound = s-1 + 0, (var(32):=0)
sparkno = -1 + 0*(var(33):=8018)
guard.sparkno = -1 + 0*(var(34):=8001)
sparkxy = -10 + 0 * (var(35) := ceil(99*const(size.xScale))), var(36):=ceil(0*const(size.yScale))
