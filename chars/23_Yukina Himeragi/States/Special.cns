;----------------------------------------------------------------------
;Wild Strike
[StateDef 1000]
type = S
physics = N
moveType = A
anim = 1000
ctrl = 0
velSet = 0,0
sprPriority = 1
powerAdd = 72 * (!var(20)&&!var(53))
faceP2 = 1

[State 1000, Button Detect]
type = VarSet
trigger1 = !Time && !AILevel
var(10) = ifElse((command = "z" || command = "rlsz"), 2, ifElse((command = "y" || command = "rlsy"), 1, 0))

[State 1000, Button Detect (AI)]
type = VarSet
trigger1 = !Time && AILevel
var(10) = ifElse(Random < 333, 2, ifElse(Random < 500, 1, 0))

[State 1000, Button Detect (Add004)]
type = VarSet
trigger1 = (var(58)&&sysfvar(4)=1) && !time
var(10) = 2
ignorehitpause = 1

[State 1000, ChangeAnim]
type = ChangeAnim
trigger1 = !Time
value = ifElse(var(10) = 2, 1002, ifElse(var(10) = 1, 1001, 1000))

[State 1000, Sekkarou]
type = Helper
trigger1 =!numhelper(7100)
trigger1 =animelem=1
helpertype = normal ;player
name ="Sekkarou"
ID =7100
stateno =7100
pos = 0,0
postype = p1
ownpal = 1
persistent=0

[State 1000, Voice]
type = PlaySnd
trigger1 = AnimElem = 5
value = 1000,random%2
channel = 0

[State 1000, Woosh Sound]
type = PlaySnd
trigger1 = AnimElem = 5
value = 1,2
channel = 1

[State 1000, VelSet]
Type = VelSet
Trigger1 = AnimElem = 5
x = 0+var(10)*10

[State 1000, VelSet]
Type = VelMul
Trigger1 = AnimElem = 5, > 0
x = .6

[State 1000, Helper]
type = Helper
trigger1 =animelem=5
helpertype = normal ;player
name ="slash"
ID =1005
stateno =1005
pos = 0,0
postype = p1
ownpal = 1
persistent=0

[State 1000, Hit]
type = hitdef
trigger1 = animelem = 5
attr = S, SA
hitflag = MAF
guardflag = MA
priority = 4, Hit
damage = ceil(ifelse(fvar(11) * ifelse(var(10) = 2, 50, ifelse(var(10) = 1, 48, 46)) < 7, 7, fvar(11) * ifelse(var(10) = 2, 50, ifelse(var(10) = 1, 48, 46)))), 7
getPower = ifElse(!var(13), 36, 18) * (!var(20)&&!var(53)), 10 * (!var(20)&&!var(53))
givePower = 18, 18
pausetime = ifelse(var(20), 6, 12), ifelse(var(20), 6, 12)
guard.pausetime = ifelse(var(20), 6, 12), ifelse(var(20), 6, 12)
animtype = Hard
air.animtype = Back
fall.animtype = Back
ground.type = Low
air.type = Low
ground.hittime = 30
ground.slidetime = 30
guard.hittime = 18
air.hittime = 120
ground.velocity = -4.49, 0
ground.cornerpush.veloff = 0
guard.velocity = -4.49
guard.cornerpush.veloff = 0
air.velocity = -3.31, -4.24
air.cornerpush.veloff = 0
yaccel = 0.58
fall = 0
air.fall = 1
fall.recover = 1
fall.recovertime = 120;37
forcestand = 1
hitsound = s-1 + 0, (var(31) := 9)
guardsound = s-1 + 0, (var(32) := 0)
sparkNo = -1 + 0 * (var(33) := 8018)
guard.sparkNo = -1 + 0 * (var(34) := 8001)
sparkXY = -10 + 0 * (var(35) := ceil(576*const(size.xScale))), var(36):=ceil(-178*const(size.yScale))
palfx.time = 12 * var(9)
palfx.add = 255, 255, 255
palfx.sinadd = -255, -255, -255, 48
envshake.time = 14
envshake.ampl = 4
envshake.freq = 120

[State 1000, StateTypeSet: Idle]
type = StateTypeSet
trigger1 = AnimElemTime(7) >= 0
moveType = I

[State 1000, Pull In]
type = ChangeState
TriggerAll = AnimElemTime(5) > 0&&AnimElemTime(7) < 0
TriggerAll = MoveContact
Trigger1 = !AILevel && (!var(58)||(var(58)&&sysfvar(4)=0))
Trigger1 = command = "x" || command = "y" || command = "z"
Trigger2 = (AILevel && (!var(58)||(var(58)&&sysfvar(4)=0))) || (var(58)&&sysfvar(4)=1)
Trigger2 = MoveHit
value = 1010
ignorehitpause = 0

[State 1000, ChangeState]
type = ChangeState
trigger1 = AnimTime = 0
value = 0
ctrl = 1
