trigger1 =! SelfAnimExist(5100) && !Time
value = 5100

[State 1226, ChangeAnim]
type = Changeanim
trigger1 = SelfAnimExist(5100) && !Time
value = 5100

[State 1226, ChangeAnim2]
type = Changeanim2
trigger1 =! SelfAnimExist(5035) && Time = 4
value = 5035

[State 1226, ChangeAnim]
type = Changeanim
trigger1 = SelfAnimExist(5035) && Time = 4
value = 5035

[State 1226, 1] ;Change anim when done with transition
type = ChangeAnim
trigger1 = AnimTime = 0
trigger1 = Anim = 5035
trigger1 = SelfAnimExist(5050)
value = 5050

[State 1226, SelfState]
type = SelfState
trigger1 = pos y > -vel y
value = 5100
