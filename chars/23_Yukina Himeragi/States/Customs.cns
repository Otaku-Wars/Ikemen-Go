;Ground Bounce-Hitting Ground
[StateDef 1226]
type = A
movetype = H
physics = N
velset = 0,0
sprpriority = 1

[State 1226]
type = PosSet
trigger1 = time = 0
y = 0

[State 1226, EnvShake]
type = EnvShake
trigger1 = !time
time = 14
ampl = 6
ignorehitpause =1

[State 1226, VelSet]
type = VelSet
trigger1 = time = 4
x = -1.5
y = -10.5

[State 1226, VelAdd]
type = Veladd
trigger1 = Time > 3
y = 0.58

[State 1226, ChangeAnim2]
