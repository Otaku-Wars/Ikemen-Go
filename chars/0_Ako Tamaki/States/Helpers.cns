[state 0] ;[.62]
	type=explod
	trigger1=1|| fvar(14):=(var(24)*24+90)*0.0174
	anim=f100010+ifelse((root,var(54)=0), 2, ifelse((root,var(54)=1), 1, ifelse((root,var(54)=2), 3, 1)))
	space=screen
	postype=left
